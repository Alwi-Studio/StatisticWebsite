# Use DATABASE_URL or the individual MYSQL_* connection variables.
# DATABASE_URL=mysql://username:password@hostname:3306/database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=statistics_reader
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=minecraft
# Enable this when your hosted MySQL provider requires TLS.
MYSQL_SSL=false

# The API account only needs SELECT permission on this table.
MYSQL_ACTIVITY_TABLE=staffactivity
MYSQL_UUID_COLUMN=uuid
MYSQL_NAME_COLUMN=name
MYSQL_LAST_ACTIVITY_COLUMN=last_activity
MYSQL_AMOUNT_CHAT_COLUMN=amount_chat
MYSQL_DAY_COLUMN=day
MYSQL_MONTH_COLUMN=month
MYSQL_YEAR_COLUMN=year

# Local development API port used by pnpm dev.
STATISTICS_API_PORT=3001
